# Copy this file to .env and fill in real values.
# Never commit the real .env file (already in .gitignore).

# ── LLM: Groq is primary, Gemini is the automatic fallback ─────────────
# Groq free tier: https://console.groq.com
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile

# Google AI Studio free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# ── Optional: live market news headline enrichment ──────────────────────
# Not required — modules/market/investment.py already pulls headlines from
# yfinance's built-in .news for free. No key needed here.
